# Python
__pycache__/
*.pyc
scripts/.venv/
.venv/

# Raw downloaded images are ephemeral inputs to the cutout step; only the
# transparent cutouts under docs/birds/ are kept.
scripts/raw/

# Cached Macaulay Library (whoBIRD) reference photos — fetched at most once per
# asset to be gentle on Cornell's CDN. Local only; copyrighted, never published.
scripts/ml_cache/

# Per-species "none good enough" retry counter (shifts seeds on re-gen). Local.
scripts/retry_rounds.json

# Prioritized image-generation job queue (local job state for gen_worker.py).
scripts/gen_queue.json

# Distribution-map reference images quarantined out of scripts/raw so img2img
# never grounds a bird on a map (see generate.py ref_images); local only.
scripts/raw_maps/

# Archived art styles (style_switch.py) — local cache for swapping the live
# style back and forth; kept off Pages/repo to avoid doubling image storage.
scripts/styles/

# Local feedback test files
scripts/votes.csv

# rembg model cache (downloaded on first run)
.u2net/

# Inspiration-only asset for the AI model — kept local, not published
layout.png

# layout preview renders (temporary)
scripts/layout_preview*.png

# Long-running job logs (generation / checkpoint watcher)
scripts/*.log
scripts/*.err

# Extracted public-domain book plates (local; large — keep off Pages/repo)
book_plates/

# Cached raw page-image downloads from Internet Archive (local; large)
.ia_cache/

# AI-regeneration QC working dirs (local only)
scripts/qc_out/
scripts/raw_badrefs/
scripts/calib/
scratch_montage/
scripts/*.log

# Manually-curated reference photos (local inputs; only thumbnails are published)
scripts/pinned_refs/
